{
  "manifest_version": 3,
  "name": "授权视频保存助手",
  "version": "1.1.0",
  "description": "仅用于保存用户本人拥有权利或已获授权页面中的直链 HTML5 视频。",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "保存授权直链视频",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      }
    },
    "download-current-video": {
      "suggested_key": {
        "default": "Alt+Shift+V"
      },
      "description": "保存当前页面授权直链视频"
    }
  }
}
